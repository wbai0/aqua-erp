# 早期简化开发账套（DATA_SOURCE=local 时使用）
DATABASE_URL="sqlserver://localhost:1433;database=cide_erp;user=sa;password=<LOCAL_SA_PASSWORD>;trustServerCertificate=true"
JWT_SECRET="<CHANGE_ME_TO_A_LONG_RANDOM_VALUE>"
PORT=3001

# 数据源：
#   local = 简化账套 cide_erp
#   cloud = 真实生产表结构，连接目标由 CLOUD_DATABASE_URL 决定
DATA_SOURCE=cloud

# 日常开发目标：本地 Docker 中的真实结构副本 cide_main_dev。
CLOUD_DATABASE_URL="sqlserver://localhost:1433;database=cide_main_dev;user=sa;password=<LOCAL_SA_PASSWORD>;trustServerCertificate=true"

# 仅供 replica:sync 和 schema:check 从生产库只读访问。
# 老版本 SQL Server 可能需要 encrypt=DANGER_PLAINTEXT；生产账号必须是只读账号。
REMOTE_DATABASE_URL="sqlserver://<REMOTE_HOST>:1433;database=cide_main;user=<READ_ONLY_USER>;password=<READ_ONLY_PASSWORD>;encrypt=DANGER_PLAINTEXT;trustServerCertificate=true"
